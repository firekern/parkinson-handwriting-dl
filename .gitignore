# Data — never commit raw or processed data
# (data/raw may be a symlink to a local dataset mount; never publish it)
/data/raw
data/raw/*
data/processed/*
!data/processed/.gitkeep

# Experiment outputs — results CSVs committed, large artifacts not
src/experiments/*/outputs/
src/experiments/*/checkpoints/
*.pt
*.pth
*.ckpt

# W&B
wandb/

# Slides deck (open-slide) — Node build artifacts
slides/**/node_modules/
slides/**/dist/
node_modules/

